// Phase 1: complete schema for User Auth, Catalog, CMS, Orders.
// All FKs are indexed; cascades chosen to keep aggregates intact (Restrict on
// product references from order_items so historical lines never break).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// 1. USER AUTH & DYNAMIC AUTHORIZATION
// =====================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id                     String      @id @default(cuid())
  email                  String      @unique
  emailVerifiedAt        DateTime?
  passwordHash           String?
  firstName              String?
  lastName               String?
  phone                  String?     @unique
  avatarUrl              String?
  status                 UserStatus  @default(ACTIVE)
  twoFactorEnabled       Boolean     @default(false)
  twoFactorSecret        String?
  twoFactorRecoveryCodes String[]    @default([])
  lastLoginAt            DateTime?
  // Session epoch: any access token issued at/before this instant is rejected
  // (see JwtStrategy). Bumped on force-logout / suspend so revocation is
  // immediate instead of waiting for the access-token TTL to lapse.
  sessionsRevokedAt      DateTime?

  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]
  userRoles           UserRole[]
  orders              Order[]
  digitalEntitlements DigitalEntitlement[]
  posts               Post[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([deletedAt])
}

model OAuthAccount {
  id             String  @id @default(cuid())
  provider       String
  providerUserId String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  accessToken    String? @db.Text
  refreshToken   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?
  isSystem    Boolean @default(false)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole {
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId     String
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

enum PermissionType {
  MENU
  ELEMENT
  API
}

model Permission {
  id          String         @id @default(cuid())
  name        String
  code        String         @unique
  type        PermissionType
  urlPath     String?
  apiEndpoint String?
  parent      Permission?    @relation("PermissionTree", fields: [parentId], references: [id], onDelete: SetNull)
  parentId    String?
  children    Permission[]   @relation("PermissionTree")

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([type])
  @@index([apiEndpoint])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  grantedAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// =====================================================================
// 2. PRODUCT CATALOG & VARIANTS
// =====================================================================

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum DigitalType {
  FILE_DOWNLOAD
  SERIAL_KEY
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String?       @db.Text
  mainImage     String?
  galleryImages Json?
  type          ProductType
  digitalType   DigitalType?
  basePrice     Decimal       @db.Decimal(12, 2)
  salePrice     Decimal?      @db.Decimal(12, 2)
  stockQuantity Int           @default(0)
  reservedStock Int           @default(0)
  weightGrams   Int?
  lengthMm      Int?
  widthMm       Int?
  heightMm      Int?
  status        ProductStatus @default(DRAFT)

  productCategories ProductCategory[]
  productTags       ProductTag[]
  attributes        ProductAttribute[]
  variants          ProductVariant[]
  orderItems        OrderItem[]
  digitalAssets     DigitalAsset[]
  serialKeys        SerialKey[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([type])
  @@index([deletedAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  parentId    String?
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)

  productCategories ProductCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model ProductCategory {
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@id([productId, categoryId])
  @@index([categoryId])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  productTags ProductTag[]
}

model ProductTag {
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([productId, tagId])
  @@index([tagId])
}

model ProductAttribute {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  name      String

  values ProductAttributeValue[]

  @@unique([productId, name])
  @@index([productId])
}

model ProductAttributeValue {
  id          String           @id @default(cuid())
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId String
  value       String

  variantValues ProductVariantValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String
  sku           String   @unique
  price         Decimal  @db.Decimal(12, 2)
  salePrice     Decimal? @db.Decimal(12, 2)
  stockQuantity Int      @default(0)
  reservedStock Int      @default(0)
  imageUrl      String?

  values     ProductVariantValue[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductVariantValue {
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId        String
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  attributeValueId String

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
}

model DigitalAsset {
  id          String  @id @default(cuid())
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  storageKey  String
  fileName    String
  fileSize    Int
  contentType String

  createdAt DateTime @default(now())

  @@index([productId])
}

model SerialKey {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  keyValue  String
  isUsed    Boolean @default(false)

  entitlement DigitalEntitlement?

  createdAt DateTime @default(now())

  @@unique([productId, keyValue])
  @@index([productId, isUsed])
}

model DigitalEntitlement {
  id          String  @id @default(cuid())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  orderItemId String?
  serialKey   SerialKey? @relation(fields: [serialKeyId], references: [id], onDelete: SetNull)
  serialKeyId String?    @unique

  downloadCount Int       @default(0)
  expiresAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderItemId])
}

// =====================================================================
// 3. CMS & LANDING PAGE
// =====================================================================

enum PageStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model Page {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  layoutJson  Json
  seoTitle    String?
  seoDesc     String?
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum MenuPosition {
  HEADER
  FOOTER
  SIDEBAR
}

model Menu {
  id            String       @id @default(cuid())
  name          String
  position      MenuPosition
  hierarchyJson Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

/// Generic key/value store for site-wide configuration edited from the admin
/// (e.g. the "footer" key holds the storefront footer layout). `valueJson` is
/// an opaque blob validated by a Zod schema in @ecom/shared at the API edge.
model SiteSetting {
  key       String   @id
  valueJson Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id              String    @id @default(cuid())
  position        String
  imageUrl        String
  targetUrl       String?
  altText         String?
  scheduleStart   DateTime?
  scheduleEnd     DateTime?
  isActive        Boolean   @default(false)
  sortOrder       Int       @default(0)
  clickCount      Int       @default(0)
  impressionCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position, isActive])
  @@index([scheduleEnd])
}

/// Reusable, pre-configured block instance. Editors save configured blocks
/// (e.g. "Summer Slider 2026") as templates, then drop them onto pages via
/// the drag-and-drop page builder. `config` is the block's props payload
/// (same shape as what shows up inside a page's `layoutJson.blocks[].props`).
model BlockTemplate {
  id           String   @id @default(cuid())
  name         String
  blockType    String
  config       Json
  previewImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blockType])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  contentHtml String     @db.Text
  coverImage  String?
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId    String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?

  postCategories PostsOnCategories[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([authorId])
}

model PostCategory {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  posts PostsOnCategories[]
}

model PostsOnCategories {
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId         String
  postCategory   PostCategory @relation(fields: [postCategoryId], references: [id], onDelete: Cascade)
  postCategoryId String

  @@id([postId, postCategoryId])
  @@index([postCategoryId])
}

// =====================================================================
// 4. ORDERS & TRANSACTIONS
// =====================================================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPING
  COMPLETED
  CANCELLED
  REFUNDED
  EXPIRED
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?
  contactEmail String?
  status       OrderStatus @default(PENDING)

  subtotal       Decimal @db.Decimal(12, 2)
  shippingFee    Decimal @default(0) @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)
  currency       String  @default("VND")

  coupon   Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponId String?

  notes            String?
  paymentExpiresAt DateTime?
  paidAt           DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?

  items    OrderItem[]
  shipping ShippingInfo?
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentExpiresAt])
}

model OrderItem {
  id        String          @id @default(cuid())
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId String
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  variantId String?

  titleSnapshot String
  unitPrice     Decimal @db.Decimal(12, 2)
  quantity      Int
  lineTotal     Decimal @db.Decimal(12, 2)

  entitlements DigitalEntitlement[]

  @@index([orderId])
  @@index([productId])
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  description   String?
  type          CouponType
  value         Decimal    @db.Decimal(12, 2)
  minOrderValue Decimal?   @db.Decimal(12, 2)
  maxDiscount   Decimal?   @db.Decimal(12, 2)
  usageLimit    Int?
  usedCount     Int        @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean    @default(true)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, expiresAt])
}

model ShippingInfo {
  id      String @id @default(cuid())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String @unique

  recipientName  String
  recipientPhone String
  addressLine    String
  ward           String?
  district       String?
  province       String?
  countryCode    String  @default("VN")
  postalCode     String?

  carrier      String?
  trackingCode String?
  shippedAt    DateTime?
  deliveredAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentProvider {
  MOMO
  VNPAY
  CREDIT_CARD
  COD
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  EXPIRED
}

model Payment {
  id            String          @id @default(cuid())
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String
  provider      PaymentProvider
  providerTxnId String?
  amount        Decimal         @db.Decimal(12, 2)
  currency      String          @default("VND")
  status        PaymentStatus   @default(PENDING)
  rawPayload    Json?
  ipnReceivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([provider, providerTxnId])
  @@index([status])
}
