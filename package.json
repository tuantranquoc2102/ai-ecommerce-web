{
  "name": "ai-ecommerce-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @ecom/db prisma:generate",
    "db:migrate": "pnpm --filter @ecom/db prisma:migrate",
    "db:seed": "pnpm --filter @ecom/db prisma:seed",
    "db:studio": "pnpm --filter @ecom/db prisma:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "@types/node": "^20.16.10"
  }
}
