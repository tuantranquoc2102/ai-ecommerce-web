DATABASE_URL="postgresql://ecom:ecom@localhost:5432/ecom?schema=public"
REDIS_URL="redis://localhost:6379"

JWT_ACCESS_SECRET="change-me-access-32-bytes-minimum-secret"
JWT_REFRESH_SECRET="change-me-refresh-32-bytes-minimum-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

PASSWORD_RESET_TTL_SECONDS=900
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

TWOFA_ISSUER="EcomCMS"

# OAuth (stubs)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/oauth/google/callback"
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:4000/api/v1/auth/oauth/facebook/callback"

# S3 / asset storage (MinIO for local dev — swap endpoint/creds for AWS in prod)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ecom"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio123"
# Public URL prefix served to browsers (may differ from S3_ENDPOINT behind CDN)
S3_PUBLIC_URL="http://localhost:9000/ecom"

# App
API_PORT=4000
WEB_PORT=3000
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# Order timeout (minutes)
ORDER_PAYMENT_TIMEOUT_MINUTES=15
ORDER_NUMBER_PREFIX="ECOM"

# Resend transactional email — https://resend.com/api-keys
# Leave RESEND_API_KEY empty in local dev; MailService will log to console instead of calling the API.
# MAIL_FROM must be a verified sender on your Resend domain in production.
RESEND_API_KEY=""
MAIL_FROM="Ecom Store <no-reply@example.com>"
MAIL_REPLY_TO=""
MAIL_BRAND_NAME="Ecom Store"

# VNPAY (sandbox defaults; fill TMN + secret from https://sandbox.vnpayment.vn)
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/checkout/return/vnpay"

# MoMo (sandbox defaults; fill partner code + keys from https://developers.momo.vn)
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_CREATE_URL="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_RETURN_URL="http://localhost:3000/checkout/return/momo"
MOMO_IPN_URL="http://localhost:4000/api/v1/payments/momo/ipn"
